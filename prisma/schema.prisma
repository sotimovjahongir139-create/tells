model AmoSyncLog {
  id          String   @id @default(cuid())
  syncedAt    DateTime @default(now()) @map("synced_at")
  status      String
  manager     String?
  eventsCount Int?     @map("events_count")
  durationMs  Int?     @map("duration_ms")
  errorMsg    String?  @map("error_msg")

  @@index([syncedAt])
  @@map("amo_sync_logs")
}
