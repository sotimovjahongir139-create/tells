# Server
PORT=3000

# AmoCRM
AMOCRM_DOMAIN=numbersarkon.amocrm.ru
AMOCRM_TOKEN=your_amocrm_long_lived_token_here

# SQL Server connection
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=calldb2

# Authentication — choose one mode:

# Mode 1: Windows Integrated Auth (only works locally on Windows with AD)
DB_TRUSTED=true

# Mode 2: SQL Server Auth (required for DigitalOcean / Linux deployment)
# DB_TRUSTED=false
# DB_USER=your_sql_login
# DB_PASSWORD=your_sql_password

# Optional: set to true if using Azure SQL or SSL-enabled SQL Server
DB_ENCRYPT=false
