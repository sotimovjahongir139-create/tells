# Server
PORT=3000

# PostgreSQL / Supabase connection string
# Format: postgresql://postgres.PROJECT_ID:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:5432/postgres

# AmoCRM
AMOCRM_DOMAIN=numbersarkon.amocrm.ru
AMOCRM_TOKEN=your_amocrm_long_lived_token_here
